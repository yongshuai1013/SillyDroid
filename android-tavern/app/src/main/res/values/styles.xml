<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="TextAppearance.SillyTavern.SettingsButton" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.SillyTavern.SettingsSectionTitle" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.SillyTavern.SettingsCardTitle" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.SillyTavern.SettingsBody" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">11sp</item>
    </style>

    <style name="TextAppearance.SillyTavern.SettingsMeta" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textSize">10sp</item>
    </style>

    <style name="TextAppearance.SillyTavern.SettingsBadge" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.SillyTavern.FloatingLogsCompactButton" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.SillyTavern.SettingsButton" parent="Widget.Material3.Button">
        <item name="android:minHeight">@dimen/stai_control_min_height</item>
        <item name="android:minWidth">@dimen/stai_control_min_width</item>
        <item name="android:paddingStart">@dimen/stai_control_padding_horizontal</item>
        <item name="android:paddingEnd">@dimen/stai_control_padding_horizontal</item>
        <item name="android:paddingTop">@dimen/stai_control_padding_vertical</item>
        <item name="android:paddingBottom">@dimen/stai_control_padding_vertical</item>
        <item name="android:textAppearance">@style/TextAppearance.SillyTavern.SettingsButton</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="Widget.SillyTavern.SettingsButton.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:minHeight">@dimen/stai_control_min_height</item>
        <item name="android:minWidth">@dimen/stai_control_min_width</item>
        <item name="android:paddingStart">@dimen/stai_control_padding_horizontal</item>
        <item name="android:paddingEnd">@dimen/stai_control_padding_horizontal</item>
        <item name="android:paddingTop">@dimen/stai_control_padding_vertical</item>
        <item name="android:paddingBottom">@dimen/stai_control_padding_vertical</item>
        <item name="android:textAppearance">@style/TextAppearance.SillyTavern.SettingsButton</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="Widget.SillyTavern.SettingsTextInputLayout.OutlinedBox" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
        <item name="helperTextTextAppearance">@style/TextAppearance.SillyTavern.SettingsMeta</item>
        <item name="hintTextAppearance">@style/TextAppearance.SillyTavern.SettingsMeta</item>
    </style>

    <style name="Widget.SillyTavern.SettingsTextInputLayout.ExposedDropdown" parent="Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
        <item name="hintTextAppearance">@style/TextAppearance.SillyTavern.SettingsMeta</item>
    </style>

    <style name="Widget.SillyTavern.SettingsDropdown" parent="Widget.Material3.AutoCompleteTextView.OutlinedBox">
        <item name="android:minHeight">@dimen/stai_input_min_height</item>
        <item name="android:paddingStart">@dimen/stai_control_padding_horizontal</item>
        <item name="android:paddingEnd">@dimen/stai_control_padding_horizontal</item>
        <item name="android:paddingTop">@dimen/stai_control_padding_vertical</item>
        <item name="android:paddingBottom">@dimen/stai_control_padding_vertical</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="Widget.SillyTavern.SettingsTextInputEditText" parent="Widget.Material3.TextInputEditText.OutlinedBox">
        <item name="android:minHeight">@dimen/stai_input_min_height</item>
        <item name="android:paddingStart">@dimen/stai_control_padding_horizontal</item>
        <item name="android:paddingEnd">@dimen/stai_control_padding_horizontal</item>
        <item name="android:paddingTop">@dimen/stai_control_padding_vertical</item>
        <item name="android:paddingBottom">@dimen/stai_control_padding_vertical</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="Widget.SillyTavern.FloatingLogsCompactButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:minHeight">@dimen/stai_floating_logs_compact_control_height</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:paddingStart">10dp</item>
        <item name="android:paddingEnd">10dp</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">0dp</item>
        <item name="android:textAppearance">@style/TextAppearance.SillyTavern.FloatingLogsCompactButton</item>
        <item name="android:textColor">@color/floating_logs_panel_title</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="backgroundTint">@color/floating_logs_panel_background</item>
        <item name="cornerRadius">@dimen/stai_floating_logs_control_corner_radius</item>
        <item name="strokeColor">@color/floating_logs_panel_stroke</item>
        <item name="strokeWidth">1dp</item>
    </style>
</resources>