<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/bootstrapSettingsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurfaceContainerLowest"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/bootstrapSettingsTopShell"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurfaceContainerLowest"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/bootstrapSettingsToolbar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/sillydroid_toolbar_height"
            android:background="@android:color/transparent"
            android:contentInsetStartWithNavigation="0dp"
            android:minHeight="@dimen/sillydroid_toolbar_height"
            android:paddingStart="0dp"
            android:paddingEnd="@dimen/sillydroid_space_xs"
            android:titleTextColor="?attr/colorOnSurface"
            app:navigationIconTint="?attr/colorOnSurface"
            app:titleTextAppearance="@style/TextAppearance.SillyDroid.SettingsToolbarTitle">

            <TextView
                android:id="@+id/bootstrapSettingsToolbarTitle"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="@dimen/sillydroid_space_sm"
                android:ellipsize="end"
                android:gravity="center_vertical"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="@string/bootstrap_settings_title"
                android:textAppearance="@style/TextAppearance.SillyDroid.SettingsToolbarTitle"
                android:textColor="?attr/colorOnSurface" />
        </com.google.android.material.appbar.MaterialToolbar>

        <TextView
            android:id="@+id/bootstrapSettingsWarning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/sillydroid_space_md"
            android:layout_marginTop="@dimen/sillydroid_space_xxxs"
            android:layout_marginEnd="@dimen/sillydroid_space_md"
            android:paddingLeft="@dimen/sillydroid_space_md"
            android:paddingTop="@dimen/sillydroid_space_sm"
            android:paddingRight="@dimen/sillydroid_space_md"
            android:paddingBottom="@dimen/sillydroid_space_sm"
            android:textSize="10sp"
            android:visibility="gone" />

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/bootstrapSettingsTabs"
            android:layout_width="match_parent"
            android:layout_height="@dimen/sillydroid_tab_height"
            android:layout_marginStart="@dimen/sillydroid_space_md"
            android:layout_marginTop="@dimen/sillydroid_space_xxxs"
            android:layout_marginEnd="@dimen/sillydroid_space_md"
            android:layout_marginBottom="0dp"
            app:tabGravity="fill"
            app:tabIndicatorFullWidth="false"
            app:tabIndicatorHeight="3dp"
            app:tabInlineLabel="true"
            app:tabMode="fixed"
            app:tabPaddingBottom="0dp"
            app:tabPaddingEnd="0dp"
            app:tabPaddingStart="0dp"
            app:tabPaddingTop="0dp"
            app:tabTextAppearance="@style/TextAppearance.SillyDroid.SettingsTab" />

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/bootstrapSettingsLoading"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/sillydroid_space_md"
            android:layout_marginTop="@dimen/sillydroid_space_xxxs"
            android:layout_marginEnd="@dimen/sillydroid_space_md"
            android:indeterminate="true"
            android:visibility="gone" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/bootstrapSettingsSearchLayout"
            style="@style/Widget.SillyDroid.SettingsTextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/sillydroid_space_md"
            android:layout_marginTop="@dimen/sillydroid_space_sm"
            android:layout_marginEnd="@dimen/sillydroid_space_md"
            android:visibility="gone"
            app:endIconMode="clear_text"
            android:hint="@string/bootstrap_settings_search_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/bootstrapSettingsSearchInput"
                style="@style/Widget.SillyDroid.SettingsTextInputEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:maxLines="1"
                android:minHeight="@dimen/sillydroid_input_min_height" />
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/bootstrapSettingsScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fadeScrollbars="false"
        android:fillViewport="true">
        android:scrollbarSize="@dimen/sillydroid_scrollbar_size"
        android:scrollbars="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/sillydroid_space_md"
            android:paddingTop="@dimen/sillydroid_space_sm"
            android:paddingEnd="@dimen/sillydroid_space_md"
            android:paddingBottom="@dimen/sillydroid_space_lg">

            <LinearLayout
                android:id="@+id/bootstrapSettingsDataPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="?attr/colorSurface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="?attr/colorOutlineVariant"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="8dp"
                        android:paddingTop="8dp"
                        android:paddingEnd="8dp"
                        android:paddingBottom="8dp">

                        <TextView
                            android:id="@+id/bootstrapSettingsSummary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/bootstrap_settings_data_summary"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="10sp" />

                        <LinearLayout
                            android:id="@+id/bootstrapSettingsQuickFieldContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:orientation="vertical" />

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="0dp"
                            app:strokeColor="?attr/colorOutlineVariant"
                            app:strokeWidth="1dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:paddingStart="8dp"
                                android:paddingTop="8dp"
                                android:paddingEnd="8dp"
                                android:paddingBottom="8dp">

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        style="@style/TextAppearance.SillyDroid.SettingsCardTitle"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:text="@string/bootstrap_settings_host_floating_logs_title"
                                        android:textColor="?attr/colorOnSurface"
                                        android:textStyle="bold" />

                                    <TextView
                                        style="@style/TextAppearance.SillyDroid.SettingsBody"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="3dp"
                                        android:text="@string/bootstrap_settings_host_floating_logs_summary"
                                        android:textColor="?attr/colorOnSurfaceVariant" />
                                </LinearLayout>

                                <com.google.android.material.materialswitch.MaterialSwitch
                                    android:id="@+id/bootstrapSettingsFloatingLogsSwitch"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:minHeight="0dp"
                                    android:minWidth="0dp"
                                    android:scaleX="0.68"
                                    android:scaleY="0.68"
                                    android:showText="false" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="@string/bootstrap_settings_config_path_label"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/bootstrapSettingsConfigPath"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:background="?attr/colorSurfaceContainerHigh"
                            android:fontFamily="monospace"
                            android:lineSpacingExtra="1dp"
                            android:paddingLeft="8dp"
                            android:paddingTop="6dp"
                            android:paddingRight="8dp"
                            android:paddingBottom="6dp"
                            android:scrollHorizontally="false"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="10sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="@string/bootstrap_settings_actions_title"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/bootstrapSettingsImportButton"
                                style="@style/Widget.SillyDroid.SettingsButton.Outlined"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="4dp"
                                android:layout_weight="1"
                                android:minHeight="@dimen/sillydroid_control_min_height"
                                android:text="@string/bootstrap_settings_import" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/bootstrapSettingsExportButton"
                                style="@style/Widget.SillyDroid.SettingsButton.Outlined"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:minHeight="@dimen/sillydroid_control_min_height"
                                android:text="@string/bootstrap_settings_export" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="@string/bootstrap_settings_clear_data_warning"
                            android:textColor="?attr/colorError"
                            android:textSize="9sp"
                            android:textStyle="bold" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/bootstrapSettingsClearDataButton"
                            style="@style/Widget.SillyDroid.SettingsButton.Outlined"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:minHeight="@dimen/sillydroid_control_min_height"
                            android:text="@string/bootstrap_settings_clear_data"
                            android:textColor="?attr/colorError"
                            app:strokeColor="?attr/colorError" />

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            app:cardBackgroundColor="?attr/colorSecondaryContainer"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:paddingStart="8dp"
                                android:paddingTop="8dp"
                                android:paddingEnd="8dp"
                                android:paddingBottom="8dp">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="@string/bootstrap_settings_import_formats_title"
                                    android:textColor="?attr/colorOnSecondaryContainer"
                                    android:textSize="10sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="3dp"
                                    android:lineSpacingExtra="1dp"
                                    android:text="@string/bootstrap_settings_import_formats_summary"
                                    android:textColor="?attr/colorOnSecondaryContainer"
                                    android:textSize="9sp" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="@string/bootstrap_settings_backup_guide_title"
                                    android:textColor="?attr/colorOnSecondaryContainer"
                                    android:textSize="10sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="3dp"
                                    android:lineSpacingExtra="1dp"
                                    android:text="@string/bootstrap_settings_backup_guide_summary"
                                    android:textColor="?attr/colorOnSecondaryContainer"
                                    android:textSize="9sp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/bootstrapSettingsExtensionsPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="?attr/colorSurface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="?attr/colorOutlineVariant"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="8dp"
                        android:paddingTop="8dp"
                        android:paddingEnd="8dp"
                        android:paddingBottom="8dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                style="@style/TextAppearance.SillyDroid.SettingsSectionTitle"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/bootstrap_settings_tab_extensions"
                                android:textColor="?attr/colorOnSurface"
                                android:textStyle="bold" />

                            <ImageButton
                                android:id="@+id/bootstrapSettingsExtensionsInstallButton"
                                android:layout_width="@dimen/sillydroid_settings_dense_icon_button_size"
                                android:layout_height="@dimen/sillydroid_settings_dense_icon_button_size"
                                android:layout_marginEnd="4dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="@string/bootstrap_settings_extensions_install"
                                android:minWidth="0dp"
                                android:minHeight="0dp"
                                android:padding="@dimen/sillydroid_settings_dense_icon_button_padding"
                                android:scaleType="centerInside"
                                android:src="@drawable/ic_add"
                                android:tint="?attr/colorPrimary" />

                            <ImageButton
                                android:id="@+id/bootstrapSettingsExtensionsBatchDeleteButton"
                                android:layout_width="@dimen/sillydroid_settings_dense_icon_button_size"
                                android:layout_height="@dimen/sillydroid_settings_dense_icon_button_size"
                                android:layout_marginEnd="4dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="@string/bootstrap_settings_extensions_action_delete_batch"
                                android:minWidth="0dp"
                                android:minHeight="0dp"
                                android:padding="@dimen/sillydroid_settings_dense_icon_button_padding"
                                android:scaleType="centerInside"
                                android:src="@drawable/ic_delete"
                                android:tint="?attr/colorError" />

                            <ImageButton
                                android:id="@+id/bootstrapSettingsExtensionsReloadButton"
                                android:layout_width="@dimen/sillydroid_settings_dense_icon_button_size"
                                android:layout_height="@dimen/sillydroid_settings_dense_icon_button_size"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="@string/bootstrap_settings_extensions_reload"
                                android:minWidth="0dp"
                                android:minHeight="0dp"
                                android:padding="@dimen/sillydroid_settings_dense_icon_button_padding"
                                android:scaleType="centerInside"
                                android:src="@drawable/ic_restore_defaults"
                                android:tint="?attr/colorOnSurfaceVariant" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/bootstrap_settings_extensions_summary"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="10sp" />

                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/bootstrapSettingsExtensionsProgress"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/bootstrapSettingsExtensionsProgressLabel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="10sp"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/bootstrapSettingsExtensionsEmpty"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:background="?attr/colorSurfaceContainerHigh"
                            android:paddingLeft="8dp"
                            android:paddingTop="8dp"
                            android:paddingRight="8dp"
                            android:paddingBottom="8dp"
                            android:text="@string/bootstrap_settings_extensions_empty"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="10sp"
                            android:visibility="gone" />

                        <LinearLayout
                            android:id="@+id/bootstrapSettingsExtensionsListContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="vertical" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>


            <LinearLayout
                android:id="@+id/bootstrapSettingsSettingsPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:minHeight="@dimen/sillydroid_control_min_height"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/bootstrap_settings_sections_title"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <ImageButton
                        android:id="@+id/bootstrapSettingsRestoreDefaultsButton"
                        android:layout_width="@dimen/sillydroid_settings_dense_icon_button_size"
                        android:layout_height="@dimen/sillydroid_settings_dense_icon_button_size"
                        android:layout_gravity="center_vertical"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/bootstrap_settings_restore_defaults"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:padding="@dimen/sillydroid_settings_dense_icon_button_padding"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_restore_defaults"
                        android:tint="?attr/colorOnSurfaceVariant" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1dp"
                    android:layout_marginBottom="6dp"
                    android:text="@string/bootstrap_settings_settings_summary"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="10sp" />

                <LinearLayout
                    android:id="@+id/bootstrapSettingsSectionContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/bootstrapSettingsAboutPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="?attr/colorSurface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="?attr/colorOutlineVariant"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="8dp"
                        android:paddingTop="8dp"
                        android:paddingEnd="8dp"
                        android:paddingBottom="8dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/bootstrap_settings_tab_about"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:lineSpacingExtra="1dp"
                            android:text="@string/bootstrap_settings_about_summary"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="10sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="@string/bootstrap_settings_about_info_title"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:lineSpacingExtra="1dp"
                            android:text="@string/bootstrap_settings_about_info_body"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="10sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="@string/bootstrap_settings_about_version_title"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/bootstrapSettingsAboutVersion"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="monospace"
                            android:lineSpacingExtra="1dp"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="10sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:cardBackgroundColor="?attr/colorSurface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="?attr/colorOutlineVariant"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="8dp"
                        android:paddingTop="8dp"
                        android:paddingEnd="8dp"
                        android:paddingBottom="8dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/bootstrap_settings_about_update_title"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/bootstrapSettingsAboutUpdateStatus"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:lineSpacingExtra="1dp"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="10sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/bootstrapSettingsAboutUpdateButton"
                            style="@style/Widget.SillyDroid.SettingsButton.Outlined"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:minHeight="@dimen/sillydroid_control_min_height"
                            android:text="@string/bootstrap_settings_about_update_action_check" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/bootstrapSettingsLogsPanel"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingTop="@dimen/sillydroid_space_sm"
        android:paddingBottom="@dimen/sillydroid_space_sm"
        android:visibility="gone">

        <!-- Fixed header section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/sillydroid_space_md"
            android:paddingEnd="@dimen/sillydroid_space_md">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/bootstrap_settings_tab_logs"
                android:textColor="?attr/colorOnSurface"
                android:textSize="12sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="start"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/bootstrapSettingsLogsSelectButton"
                    style="@style/Widget.SillyDroid.SettingsButton.Outlined"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:minHeight="@dimen/sillydroid_control_min_height"
                    android:text="@string/bootstrap_settings_logs_select" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/bootstrapSettingsLogsExportButton"
                    style="@style/Widget.SillyDroid.SettingsButton.Outlined"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:minHeight="@dimen/sillydroid_control_min_height"
                    android:text="@string/bootstrap_settings_logs_export" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/bootstrapSettingsLogsReloadButton"
                    style="@style/Widget.SillyDroid.SettingsButton.Outlined"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minHeight="@dimen/sillydroid_control_min_height"
                    android:text="@string/bootstrap_settings_logs_reload" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/bootstrap_settings_logs_summary"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/bootstrapSettingsLogsMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="?attr/colorOnSurface"
                android:textSize="10sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Scrollable content area (takes remaining space) -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="@dimen/sillydroid_space_sm"
            android:layout_marginStart="@dimen/sillydroid_space_md"
            android:layout_marginEnd="@dimen/sillydroid_space_md">

            <androidx.core.widget.NestedScrollView
                android:id="@+id/bootstrapSettingsLogsScrollView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="?attr/colorSurfaceContainerHigh"
                android:fadeScrollbars="false"
                android:scrollbarSize="@dimen/sillydroid_scrollbar_size"
                android:scrollbars="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/bootstrapSettingsLogsEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="8dp"
                        android:text="@string/bootstrap_settings_logs_empty"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="10sp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/bootstrapSettingsLogsContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:lineSpacingExtra="1dp"
                        android:padding="8dp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textIsSelectable="true"
                        android:textSize="9sp"
                        android:visibility="gone" />
                </LinearLayout>
            </androidx.core.widget.NestedScrollView>

            <ImageButton
                android:id="@+id/bootstrapSettingsLogsScrollToBottomButton"
                android:layout_width="@dimen/sillydroid_compact_icon_button_size"
                android:layout_height="@dimen/sillydroid_compact_icon_button_size"
                android:layout_gravity="bottom|end"
                android:layout_margin="8dp"
                android:background="?attr/colorPrimaryContainer"
                android:contentDescription="@string/bootstrap_settings_logs_scroll_to_bottom"
                android:padding="@dimen/sillydroid_compact_icon_button_padding"
                android:scaleType="centerInside"
                android:src="@drawable/ic_scroll_to_bottom"
                android:tint="?attr/colorOnPrimaryContainer"
                android:visibility="gone" />
        </FrameLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/bootstrapSettingsActionBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        android:elevation="8dp"
        android:orientation="vertical"
        android:paddingStart="@dimen/sillydroid_space_md"
        android:paddingTop="@dimen/sillydroid_space_sm"
        android:paddingEnd="@dimen/sillydroid_space_md"
        android:paddingBottom="@dimen/sillydroid_space_md">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/bootstrapSettingsSaveButton"
            style="@style/Widget.SillyDroid.SettingsButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/sillydroid_control_min_height"
            android:text="@string/bootstrap_settings_save_start" />
    </LinearLayout>

</LinearLayout>
