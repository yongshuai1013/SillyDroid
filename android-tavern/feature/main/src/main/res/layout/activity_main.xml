<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/hostSurfaceRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <FrameLayout
        android:id="@+id/contentRoot"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <FrameLayout
            android:id="@+id/webViewRefreshLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/tavern_webview_background"
            android:visibility="gone">

            <WebView
                android:id="@+id/webView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/tavern_webview_background" />
        </FrameLayout>

        <View
            android:id="@+id/webViewPullRefreshHintArc"
            android:layout_width="match_parent"
            android:layout_height="88dp"
            android:layout_gravity="top"
            android:alpha="0"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/webViewPullRefreshHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:alpha="0"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_bootstrap_overlay_icon_button"
                android:backgroundTint="?attr/colorSurface"
                android:elevation="6dp"
                android:foregroundGravity="center"
                android:outlineProvider="background"
                android:translationZ="10dp">

                <ImageView
                    android:id="@+id/webViewPullRefreshHintIcon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:alpha="0.45"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_restore_defaults"
                    android:tint="?attr/colorOnSurface" />
            </FrameLayout>

            <TextView
                android:id="@+id/webViewPullRefreshHintText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sillydroid_space_xs"
                android:alpha="0"
                android:background="@drawable/bg_bootstrap_overlay_icon_button"
                android:backgroundTint="?attr/colorSurface"
                android:elevation="4dp"
                android:outlineProvider="background"
                android:paddingStart="@dimen/sillydroid_space_sm"
                android:paddingTop="@dimen/sillydroid_space_xs"
                android:paddingEnd="@dimen/sillydroid_space_sm"
                android:paddingBottom="@dimen/sillydroid_space_xs"
                android:text="@string/webview_pull_refresh_pull"
                android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"
                android:textColor="?attr/colorOnSurface" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/bootstrapOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/bootstrap_overlay_background"
            android:orientation="vertical"
            android:padding="@dimen/sillydroid_space_3xl">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/sillydroid_space_md">

                <ProgressBar
                    android:id="@+id/bootstrapProgress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="@dimen/sillydroid_bootstrap_progress_width"
                    android:layout_height="@dimen/sillydroid_bootstrap_progress_height"
                    android:layout_marginBottom="@dimen/sillydroid_space_lg"
                    android:max="100"
                    android:progress="0" />

                <TextView
                    android:id="@+id/bootstrapProgressLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/sillydroid_space_4xl"
                    android:text="@string/bootstrap_progress_indeterminate"
                    android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"
                    android:textColor="@color/bootstrap_overlay_secondary_text" />

                <TextView
                    android:id="@+id/bootstrapTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/sillydroid_space_md"
                    android:text="@string/bootstrap_title"
                    android:textAppearance="@style/TextAppearance.MaterialComponents.Headline6"
                    android:textColor="@color/bootstrap_overlay_title" />

                <TextView
                    android:id="@+id/bootstrapStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/bootstrap_idle"
                    android:textAppearance="@style/TextAppearance.MaterialComponents.Body1"
                    android:textColor="@color/bootstrap_overlay_body" />

                <Button
                    android:id="@+id/bootstrapRetry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/sillydroid_space_3xl"
                    android:text="@string/bootstrap_retry"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/bootstrapTopActionBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/sillydroid_space_3xl">

            <LinearLayout
                android:id="@+id/bootstrapUpdateButtonContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/sillydroid_space_lg"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone">

                <!-- 启动页发现可用 App 更新时，在设置入口左侧直接露出提示文案和更新按钮。 -->
                <TextView
                    android:id="@+id/bootstrapUpdateHint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/sillydroid_space_sm"
                    android:background="@drawable/bg_bootstrap_overlay_icon_button"
                    android:includeFontPadding="false"
                    android:paddingStart="@dimen/sillydroid_space_lg"
                    android:paddingTop="@dimen/sillydroid_space_sm"
                    android:paddingEnd="@dimen/sillydroid_space_lg"
                    android:paddingBottom="@dimen/sillydroid_space_sm"
                    android:text="@string/bootstrap_update_available_hint"
                    android:textColor="@color/bootstrap_overlay_body"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <ImageButton
                        android:id="@+id/bootstrapUpdateButton"
                        android:layout_width="@dimen/sillydroid_overlay_icon_button_size"
                        android:layout_height="@dimen/sillydroid_overlay_icon_button_size"
                        android:background="@drawable/bg_bootstrap_overlay_icon_button"
                        android:contentDescription="@string/bootstrap_update_open"
                        android:padding="@dimen/sillydroid_overlay_icon_button_padding"
                        android:src="@android:drawable/stat_sys_download_done"
                        android:tint="@color/bootstrap_overlay_icon_tint" />

                    <View
                        android:id="@+id/bootstrapUpdateBadge"
                        android:layout_width="@dimen/sillydroid_bootstrap_badge_size"
                        android:layout_height="@dimen/sillydroid_bootstrap_badge_size"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="@dimen/sillydroid_space_lg"
                        android:layout_marginEnd="@dimen/sillydroid_space_lg"
                        android:background="@drawable/bg_bootstrap_update_badge"
                        android:contentDescription="@string/bootstrap_update_available_badge"
                        android:visibility="gone" />
                </FrameLayout>
            </LinearLayout>

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <ImageButton
                    android:id="@+id/bootstrapSettingsButton"
                    android:layout_width="@dimen/sillydroid_overlay_icon_button_size"
                    android:layout_height="@dimen/sillydroid_overlay_icon_button_size"
                    android:background="@drawable/bg_bootstrap_overlay_icon_button"
                    android:contentDescription="@string/bootstrap_settings_open"
                    android:padding="@dimen/sillydroid_overlay_icon_button_padding"
                    android:src="@drawable/ic_bootstrap_settings"
                    android:tint="@color/bootstrap_overlay_icon_tint" />

                <View
                    android:id="@+id/bootstrapSettingsUpdateBadge"
                    android:layout_width="@dimen/sillydroid_bootstrap_badge_size"
                    android:layout_height="@dimen/sillydroid_bootstrap_badge_size"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="@dimen/sillydroid_space_lg"
                    android:layout_marginEnd="@dimen/sillydroid_space_lg"
                    android:background="@drawable/bg_bootstrap_update_badge"
                    android:contentDescription="@string/bootstrap_update_available_badge"
                    android:visibility="gone" />
            </FrameLayout>
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/floatingLogsPanel"
            android:layout_width="@dimen/sillydroid_floating_logs_panel_width"
            android:layout_height="@dimen/sillydroid_floating_logs_panel_height"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="88dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/floating_logs_panel_background"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:strokeColor="@color/floating_logs_panel_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingStart="@dimen/sillydroid_space_md"
                android:paddingTop="@dimen/sillydroid_space_md"
                android:paddingEnd="@dimen/sillydroid_space_md"
                android:paddingBottom="@dimen/sillydroid_space_md">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/floating_logs_panel_title"
                        android:textAppearance="@style/TextAppearance.SillyDroid.SettingsSectionTitle"
                        android:textColor="@color/floating_logs_panel_title" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/floatingLogsSelectButton"
                        style="@style/Widget.SillyDroid.FloatingLogsCompactButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/sillydroid_space_sm"
                        android:ellipsize="end"
                        android:maxWidth="@dimen/sillydroid_floating_logs_select_control_width"
                        android:maxLines="1"
                        android:text="@string/floating_logs_panel_auto_select_label" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/floatingLogsIntervalButton"
                        style="@style/Widget.SillyDroid.FloatingLogsCompactButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/sillydroid_space_sm"
                        android:ellipsize="end"
                        android:maxWidth="@dimen/sillydroid_floating_logs_interval_control_width"
                        android:maxLines="1"
                        android:text="@string/bootstrap_settings_host_floating_logs_refresh_interval_one_second" />

                    <ImageButton
                        android:id="@+id/floatingLogsCloseButton"
                        android:layout_width="@dimen/sillydroid_settings_dense_icon_button_size"
                        android:layout_height="@dimen/sillydroid_settings_dense_icon_button_size"
                        android:layout_marginStart="@dimen/sillydroid_space_xs"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/floating_logs_panel_close"
                        android:padding="@dimen/sillydroid_settings_dense_icon_button_padding"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_close"
                        android:tint="@color/floating_logs_panel_secondary_text" />
                </LinearLayout>

                <TextView
                    android:id="@+id/floatingLogsMeta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/sillydroid_space_sm"
                    android:background="@drawable/bg_floating_logs_panel_surface"
                    android:paddingStart="@dimen/sillydroid_space_md"
                    android:paddingTop="@dimen/sillydroid_space_sm"
                    android:paddingEnd="@dimen/sillydroid_space_md"
                    android:paddingBottom="@dimen/sillydroid_space_sm"
                    android:textAppearance="@style/TextAppearance.SillyDroid.SettingsBody"
                    android:textColor="@color/floating_logs_panel_secondary_text"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/floatingLogsEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/sillydroid_space_sm"
                    android:background="@drawable/bg_floating_logs_panel_surface"
                    android:padding="@dimen/sillydroid_space_md"
                    android:text="@string/bootstrap_settings_logs_empty"
                    android:textAppearance="@style/TextAppearance.SillyDroid.SettingsBody"
                    android:textColor="@color/floating_logs_panel_secondary_text"
                    android:visibility="gone" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="@dimen/sillydroid_space_sm"
                    android:layout_weight="1">

                    <androidx.core.widget.NestedScrollView
                        android:id="@+id/floatingLogsScroll"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_floating_logs_panel_surface"
                        android:fadeScrollbars="false"
                        android:fillViewport="true">

                        <TextView
                            android:id="@+id/floatingLogsContent"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:lineSpacingExtra="1dp"
                            android:padding="@dimen/sillydroid_space_md"
                            android:textAppearance="@style/TextAppearance.SillyDroid.SettingsMeta"
                            android:textColor="@color/floating_logs_panel_content"
                            android:textIsSelectable="true"
                            android:visibility="gone" />
                    </androidx.core.widget.NestedScrollView>

                    <View
                        android:id="@+id/floatingLogsScrollbarThumb"
                        android:layout_width="@dimen/sillydroid_floating_logs_scrollbar_hit_width"
                        android:layout_height="@dimen/sillydroid_floating_logs_scrollbar_min_height"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="@dimen/sillydroid_floating_logs_scrollbar_vertical_margin"
                        android:layout_marginEnd="@dimen/sillydroid_floating_logs_scrollbar_end_margin"
                        android:layout_marginBottom="@dimen/sillydroid_floating_logs_scrollbar_vertical_margin"
                        android:background="@drawable/bg_floating_logs_scrollbar_thumb"
                        android:clickable="true"
                        android:visibility="gone" />

                    <ImageButton
                        android:id="@+id/floatingLogsScrollToBottomButton"
                        android:layout_width="@dimen/sillydroid_settings_dense_icon_button_size"
                        android:layout_height="@dimen/sillydroid_settings_dense_icon_button_size"
                        android:layout_gravity="bottom|end"
                        android:layout_margin="6dp"
                        android:background="@drawable/bg_floating_logs_panel_surface"
                        android:contentDescription="@string/floating_logs_scroll_to_bottom"
                        android:padding="@dimen/sillydroid_settings_dense_icon_button_padding"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_scroll_to_bottom"
                        android:tint="@color/floating_logs_panel_secondary_text"
                        android:visibility="gone" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/sillydroid_space_sm"
                    android:gravity="start|center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/floatingLogsReloadWebViewButton"
                        style="@style/Widget.SillyDroid.FloatingLogsCompactButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/floating_logs_reload_webview_button" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/floatingLogsDownloadButton"
                        style="@style/Widget.SillyDroid.FloatingLogsCompactButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/sillydroid_space_sm"
                        android:text="@string/floating_logs_download_button" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/floatingLogsClearButton"
                        style="@style/Widget.SillyDroid.FloatingLogsCompactButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/sillydroid_space_sm"
                        android:text="@string/floating_logs_clear_button"
                        android:textColor="?attr/colorError"
                        app:strokeColor="?attr/colorError" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/floatingLogsOpenSettingsButton"
                        style="@style/Widget.SillyDroid.FloatingLogsCompactButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/sillydroid_space_sm"
                        android:text="@string/floating_logs_open_settings_button" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/floatingLogsOpenBrowserButton"
                        style="@style/Widget.SillyDroid.FloatingLogsCompactButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/sillydroid_space_sm"
                        android:text="@string/floating_logs_open_browser_button" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/sillydroid_space_sm"
                    android:gravity="start|center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/floatingLogsFeedbackButton"
                        style="@style/Widget.SillyDroid.FloatingLogsCompactButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/floating_logs_feedback_button" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <ImageButton
            android:id="@+id/floatingLogsBubble"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="18dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/bg_floating_logs_bubble"
            android:contentDescription="@string/floating_logs_bubble_description"
            android:elevation="14dp"
            android:padding="15dp"
            android:scaleType="center"
            android:src="@drawable/ic_bootstrap_settings"
            android:tint="@color/floating_logs_bubble_text"
            android:visibility="gone" />
    </FrameLayout>

    <View
        android:id="@+id/statusBarBackground"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_gravity="top"
        android:importantForAccessibility="no" />

    <View
        android:id="@+id/navigationBarBackground"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_gravity="bottom"
        android:importantForAccessibility="no" />

</FrameLayout>
